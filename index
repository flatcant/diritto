<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>L'Architettura della Giustizia</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root {
  --navy: #1a2340;
  --navy-mid: #2d3a5c;
  --gold: #c8a96e;
  --gold-light: #e8c98e;
  --rust: #b85c38;
  --rust-light: #d47050;
  --cream: #f5f0e8;
  --cream-dark: #ede5d5;
  --white: #ffffff;
  --text-dark: #1a1a1a;
  --text-mid: #4a4a4a;
  --text-light: #8a8a8a;
  --grid-color: rgba(26,35,64,0.06);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);overflow-x:hidden;}

/* GRID BACKGROUND */
body::before{
  content:'';position:fixed;top:0;left:0;width:100%;height:100%;
  background-image:linear-gradient(var(--grid-color) 1px,transparent 1px),linear-gradient(90deg,var(--grid-color) 1px,transparent 1px);
  background-size:40px 40px;pointer-events:none;z-index:0;
}

/* LANGUAGE SWITCHER */
.lang-bar{
  position:fixed;top:0;right:0;z-index:1000;
  display:flex;gap:0;
}
.lang-btn{
  padding:8px 20px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;
  letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border:none;
  background:var(--navy);color:rgba(255,255,255,0.5);transition:all 0.3s;
}
.lang-btn.active{background:var(--gold);color:var(--navy);}
.lang-btn:hover:not(.active){color:var(--white);}

/* BACK BUTTON */
.back-btn{
  position:fixed;top:0;left:0;z-index:1000;
  padding:8px 20px;background:var(--navy);color:var(--gold);
  font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;
  letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border:none;
  display:none;transition:all 0.3s;
}
.back-btn:hover{background:var(--navy-mid);}
.back-btn.visible{display:block;}

/* PAGES */
.page{position:relative;z-index:1;min-height:100vh;display:none;}
.page.active{display:block;}

/* ===================== HOME PAGE ===================== */
#home-page{padding:0;}

.hero{
  min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:80px 40px 60px;text-align:center;position:relative;
}
.hero-tag{
  font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);
  font-weight:500;margin-bottom:24px;
}
.hero h1{
  font-family:'Playfair Display',serif;font-size:clamp(48px,8vw,100px);
  font-weight:900;line-height:0.92;color:var(--navy);margin-bottom:16px;
  animation:fadeUp 1s ease both;
}
.hero h1 span{color:var(--gold);}
.hero-sub{
  font-size:clamp(14px,2vw,18px);color:var(--text-mid);max-width:500px;
  line-height:1.6;margin-bottom:60px;animation:fadeUp 1s 0.2s ease both;
}
.scroll-hint{
  font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-light);
  animation:pulse 2s infinite;
}

/* SECTION LABEL */
.section-label{
  font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);
  font-weight:500;padding:80px 60px 32px;
}

/* CARDS GRID */
.cards-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:2px;padding:0 2px 2px;
}
.card{
  background:var(--white);padding:48px 40px;cursor:pointer;
  position:relative;overflow:hidden;transition:all 0.4s cubic-bezier(0.16,1,0.3,1);
  border-top:3px solid transparent;
}
.card::before{
  content:'';position:absolute;top:0;left:0;width:100%;height:100%;
  background:var(--navy);transform:translateY(101%);transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);
  z-index:0;
}
.card:hover::before{transform:translateY(0);}
.card:hover .card-num,.card:hover .card-title,.card:hover .card-desc,.card:hover .card-arrow{color:var(--white);}
.card:hover .card-accent{background:var(--gold);}
.card-accent{
  width:40px;height:3px;background:var(--rust);margin-bottom:32px;
  transition:background 0.3s;position:relative;z-index:1;
}
.card-num{
  font-family:'Playfair Display',serif;font-size:13px;color:var(--text-light);
  margin-bottom:16px;position:relative;z-index:1;transition:color 0.3s;
  letter-spacing:0.1em;
}
.card-title{
  font-family:'Playfair Display',serif;font-size:26px;font-weight:700;
  color:var(--navy);line-height:1.15;margin-bottom:16px;
  position:relative;z-index:1;transition:color 0.3s;
}
.card-desc{
  font-size:14px;color:var(--text-mid);line-height:1.6;
  position:relative;z-index:1;transition:color 0.3s;
}
.card-arrow{
  position:absolute;bottom:40px;right:40px;font-size:24px;color:var(--navy-mid);
  transition:all 0.4s;position:relative;z-index:1;text-align:right;margin-top:32px;
}
.card:hover .card-arrow{transform:translate(4px,-4px);}

/* FOOTER */
.home-footer{
  padding:60px;text-align:center;
  border-top:1px solid var(--cream-dark);
  font-size:12px;color:var(--text-light);letter-spacing:0.1em;
}

/* ===================== DETAIL PAGE ===================== */
#detail-page{padding:0;}

.detail-hero{
  background:var(--navy);padding:120px 80px 80px;position:relative;overflow:hidden;
}
.detail-hero::after{
  content:'';position:absolute;top:-50%;right:-10%;width:600px;height:600px;
  border:1px solid rgba(200,169,110,0.15);border-radius:50%;
}
.detail-hero::before{
  content:'';position:absolute;top:-30%;right:5%;width:300px;height:300px;
  border:1px solid rgba(200,169,110,0.08);border-radius:50%;
}
.detail-chapter{
  font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);
  margin-bottom:24px;position:relative;z-index:1;
}
.detail-hero h2{
  font-family:'Playfair Display',serif;font-size:clamp(36px,6vw,72px);
  font-weight:900;color:var(--white);line-height:1;max-width:700px;
  position:relative;z-index:1;
}
.detail-hero h2 span{color:var(--gold);}
.detail-lead{
  font-size:18px;color:rgba(255,255,255,0.6);max-width:600px;line-height:1.7;
  margin-top:24px;position:relative;z-index:1;
}

/* CONTENT SECTIONS */
.detail-body{max-width:900px;margin:0 auto;padding:80px 60px;}

.content-block{margin-bottom:72px;animation:fadeUp 0.6s ease both;}

.block-label{
  font-size:11px;letter-spacing:0.25em;text-transform:uppercase;
  color:var(--rust);font-weight:500;margin-bottom:16px;
}
.block-title{
  font-family:'Playfair Display',serif;font-size:32px;font-weight:700;
  color:var(--navy);margin-bottom:20px;line-height:1.2;
}
.block-text{
  font-size:16px;color:var(--text-mid);line-height:1.8;margin-bottom:20px;
}
.block-text strong{color:var(--navy);font-weight:500;}

/* INFO BOXES */
.info-box{
  background:var(--white);border-left:4px solid var(--gold);
  padding:28px 32px;margin:32px 0;position:relative;
}
.info-box.rust{border-left-color:var(--rust);}
.info-box.navy{border-left-color:var(--navy);}
.info-box-title{
  font-size:12px;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--gold);font-weight:500;margin-bottom:10px;
}
.info-box.rust .info-box-title{color:var(--rust);}
.info-box.navy .info-box-title{color:var(--navy);}
.info-box p{font-size:15px;color:var(--text-mid);line-height:1.7;}

/* COMPARISON GRID */
.compare-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:3px;margin:32px 0;
}
.compare-col{background:var(--white);padding:32px;}
.compare-col.dark{background:var(--navy);}
.compare-col-title{
  font-family:'Playfair Display',serif;font-size:22px;font-weight:700;
  color:var(--navy);margin-bottom:20px;
}
.compare-col.dark .compare-col-title{color:var(--white);}
.compare-item{
  padding:12px 0;border-bottom:1px solid var(--cream-dark);
  font-size:14px;color:var(--text-mid);line-height:1.5;
}
.compare-col.dark .compare-item{color:rgba(255,255,255,0.6);border-color:rgba(255,255,255,0.08);}
.compare-item:last-child{border-bottom:none;}
.compare-item strong{color:var(--navy);display:block;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px;}
.compare-col.dark .compare-item strong{color:var(--gold);}

/* STEPS */
.steps{display:flex;flex-direction:column;gap:0;margin:32px 0;}
.step{
  display:flex;gap:24px;padding:28px 0;
  border-bottom:1px solid var(--cream-dark);
}
.step:last-child{border-bottom:none;}
.step-num{
  font-family:'Playfair Display',serif;font-size:36px;font-weight:900;
  color:var(--cream-dark);flex-shrink:0;line-height:1;min-width:48px;
}
.step-content{}
.step-title{font-size:16px;font-weight:500;color:var(--navy);margin-bottom:6px;}
.step-text{font-size:14px;color:var(--text-mid);line-height:1.6;}

/* PILL BADGES */
.badges{display:flex;flex-wrap:wrap;gap:8px;margin:20px 0;}
.badge{
  padding:6px 16px;font-size:12px;font-weight:500;letter-spacing:0.05em;
  border:1px solid;
}
.badge.gold{border-color:var(--gold);color:var(--gold);}
.badge.rust{border-color:var(--rust);color:var(--rust);}
.badge.navy{border-color:var(--navy);color:var(--navy);}

/* QUOTE */
.pull-quote{
  font-family:'Playfair Display',serif;font-size:22px;font-weight:400;
  color:var(--navy);line-height:1.5;padding:40px 0;
  border-top:2px solid var(--gold);border-bottom:2px solid var(--gold);
  margin:48px 0;
}

/* REFORM TOGGLE */
.reform-toggle{
  display:flex;gap:3px;margin:32px 0;
}
.reform-panel{
  flex:1;padding:32px;cursor:pointer;background:var(--white);
  transition:all 0.3s;position:relative;overflow:hidden;
}
.reform-panel.active-panel{background:var(--navy);}
.reform-panel-tag{
  font-size:11px;letter-spacing:0.2em;text-transform:uppercase;
  font-weight:500;margin-bottom:12px;color:var(--text-light);
}
.reform-panel.active-panel .reform-panel-tag{color:var(--gold);}
.reform-panel-title{font-family:'Playfair Display',serif;font-size:20px;color:var(--navy);margin-bottom:16px;}
.reform-panel.active-panel .reform-panel-title{color:var(--white);}
.reform-panel ul{list-style:none;padding:0;}
.reform-panel ul li{
  font-size:14px;color:var(--text-mid);padding:8px 0;
  border-bottom:1px solid var(--cream-dark);line-height:1.5;
}
.reform-panel.active-panel ul li{color:rgba(255,255,255,0.65);border-color:rgba(255,255,255,0.08);}
.reform-panel ul li:last-child{border-bottom:none;}

/* NAVIGATION FOOTER */
.nav-footer{
  background:var(--navy);padding:60px 80px;
  display:flex;align-items:center;justify-content:space-between;gap:20px;
  flex-wrap:wrap;
}
.nav-footer-text{
  font-size:12px;letter-spacing:0.15em;text-transform:uppercase;
  color:rgba(255,255,255,0.3);
}
.nav-btns{display:flex;gap:12px;}
.nav-btn{
  padding:12px 28px;font-family:'DM Sans',sans-serif;font-size:12px;
  font-weight:500;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;
  border:1px solid rgba(255,255,255,0.2);background:transparent;
  color:rgba(255,255,255,0.6);transition:all 0.3s;
}
.nav-btn:hover{border-color:var(--gold);color:var(--gold);}
.nav-btn.primary{background:var(--gold);border-color:var(--gold);color:var(--navy);}
.nav-btn.primary:hover{background:var(--gold-light);}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px);}to{opacity:1;transform:translateY(0);}}
@keyframes pulse{0%,100%{opacity:0.4;}50%{opacity:1;}}

.fade-in{animation:fadeUp 0.5s ease both;}

/* RESPONSIVE */
@media(max-width:768px){
  .hero{padding:80px 24px 40px;}
  .section-label{padding:60px 24px 24px;}
  .cards-grid{grid-template-columns:1fr;}
  .card{padding:36px 28px;}
  .detail-hero{padding:100px 32px 60px;}
  .detail-body{padding:48px 32px;}
  .compare-grid{grid-template-columns:1fr;}
  .reform-toggle{flex-direction:column;}
  .nav-footer{padding:40px 32px;}
}
</style>
</head>
